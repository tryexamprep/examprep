# =====================================================
# ExamPrep - Environment Variables
# =====================================================
# Copy this file to .env and fill in your own values

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI (Gemini) ----
# Get a free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Fallback paid key used when the free quota is exhausted (optional).
GEMINI_API_KEY_PAID=
# Model: gemini-2.0-flash-exp (free tier) or gemini-2.0-flash (paid)
GEMINI_MODEL=gemini-2.0-flash-exp

# ---- AI (Groq — free explanation generation, falls back to Gemini) ----
# Get a free API key from https://console.groq.com
GROQ_API_KEY=

# ---- Stripe (subscriptions) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EDUCATION=

# ---- Email notifications (Resend) ----
# Get a free API key from https://resend.com
RESEND_API_KEY=
# Email address to receive contact form notifications
CONTACT_NOTIFY_EMAIL=

# ---- App settings ----
APP_TITLE=ExamPrep - תרגול שאלות אמריקאיות
APP_URL=https://examprep.vercel.app
PORT=3000

# ---- Cloudinary (image storage — free, no credit card required) ----
# Sign up free at cloudinary.com — no credit card needed (25 GB free)
# Dashboard → Settings → API Keys → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Anti-abuse ----
# Salt for SHA-256(IP) used by ipAbuseGuard. Must be the same value across
# all server replicas (Vercel functions) or hashes won't match. Set this in
# your hosting provider's env settings, never commit it.
IP_HASH_SALT=

# ---- Rate limiting (persistent) ----
# Upstash Redis for rate limiting that survives Vercel cold starts.
# Get free at https://upstash.com
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ---- CAPTCHA (Cloudflare Turnstile) ----
# Free CAPTCHA for signup protection. https://dash.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=
