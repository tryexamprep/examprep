# =====================================================
# ExamPrep - Environment Variables
# =====================================================
# Copy this file to .env and fill in your own values

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI (Gemini for similar question generation) ----
# Get a free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model: gemini-2.0-flash-exp (free tier) or gemini-2.0-flash (paid)
GEMINI_MODEL=gemini-2.0-flash-exp

# ---- Stripe (subscriptions) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EDUCATION=

# ---- App settings ----
APP_TITLE=ExamPrep - תרגול שאלות אמריקאיות
APP_URL=https://examprep.vercel.app
PORT=3000

# ---- Quotas (free tier) ----
FREE_PDF_LIMIT=5
FREE_DAILY_PDFS=2
FREE_AI_QUESTIONS=0
FREE_COURSES=1
FREE_STORAGE_MB=100
